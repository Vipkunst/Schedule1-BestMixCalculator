@model Schedule_1_Calculator.ViewModel.HomeViewModel

@{
    ViewData["Title"] = "Mix Calculator";
}

@functions {
    // "mega_bean" -> "Mega Bean", "og_kush" -> "OG Kush"
    string Pretty(string id) =>
        System.Globalization.CultureInfo.CurrentCulture.TextInfo
            .ToTitleCase(id.Replace("_", " "))
            .Replace("Og ", "OG ");
}

<section class="mixer">
    <header class="mixer__intro">
        <h1 class="mixer__title">Mix Calculator</h1>
        <p class="mixer__subtitle">Find the most profitable recipe for any product.</p>
    </header>

    <form class="mix-form" method="get" asp-controller="Home" asp-action="Mix">
        <div class="mix-form__field">
            <label class="mix-form__label" for="product">Base Product</label>
            <select class="mix-form__select" id="product" name="product">
                @foreach (var product in Model.BaseProducts)
                {
                    if (product.Id == Model.SelectedProductId)
                    {
                        <option value="@product.Id" selected>@Pretty(product.Id)</option>
                    }
                    else
                    {
                        <option value="@product.Id">@Pretty(product.Id)</option>
                    }
                }
            </select>
        </div>

        <div class="mix-form__field">
            <label class="mix-form__label" for="count">Ingredients</label>
            <select class="mix-form__select" id="count" name="count">
                @for (int i = 1; i <= 8; i++)
                {
                    if (i == Model.SelectedIngredientCount)
                    {
                        <option value="@i" selected>@i</option>
                    }
                    else
                    {
                        <option value="@i">@i</option>
                    }
                }
            </select>
        </div>

        <button class="mix-form__submit" type="submit">Calculate</button>
    </form>

    <article class="recipe">
        <h2 class="recipe__heading">Best @Model.BestComboIngredients.Count-Ingredient Mix</h2>

        <div class="stats">
            <div class="stat stat--price">
                <span class="stat__label">Sell Price</span>
                <span class="stat__value">$@Model.BestSellPrice.ToString("0")</span>
            </div>
            <div class="stat stat--cost">
                <span class="stat__label">Ingredient Cost</span>
                <span class="stat__value">$@Model.BestComboCost.ToString("0")</span>
            </div>
            <div class="stat stat--profit">
                <span class="stat__label">Profit</span>
                <span class="stat__value">$@Model.BestProfit.ToString("0")</span>
            </div>
        </div>

        <div class="recipe__section">
            <h3 class="recipe__subheading">Mixing Order</h3>
            <ol class="ingredient-chain">
                @foreach (var ingredient in Model.BestComboIngredients)
                {
                    <li class="ingredient">@Pretty(ingredient.Id)</li>
                }
            </ol>
        </div>

        <div class="recipe__section">
            <h3 class="recipe__subheading">Effects &middot; @Model.BestComboEffects.Count</h3>
            <ul class="effect-list">
                @foreach (var effect in Model.BestComboEffects)
                {
                    var isBonus = effect.Value > 0;
                    <li class="effect @(isBonus ? "effect--bonus" : "effect--drawback")" title="@Pretty(effect.Id)">
                        <span class="effect__abbr">@effect.Abbr</span>
                        <span class="effect__name">@Pretty(effect.Id)</span>
                        <span class="effect__mult">@(isBonus ? "+" + (effect.Value * 100).ToString("0") + "%" : "—")</span>
                    </li>
                }
            </ul>
        </div>
    </article>
    <div class="btn-wrapper">
        <button class="copy-button" onclick="copyMixUrl(this)">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg><span class="copy-button__label">Copy URL</span>
        </button>
        <button class="copy-button" onclick="copyMixImage(this)">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <path d="M21 15l-5-5L5 21"></path>
            </svg><span class="copy-button__label">Copy Image</span>
        </button>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.13/dist/html-to-image.js"></script>
<script>
    // Briefly swap the button label to give feedback, then restore it.
    function flashButton(btn, message) {
        const label = btn.querySelector('.copy-button__label');
        const original = label.textContent;
        btn.classList.add('copy-button--copied');
        label.textContent = message;
        setTimeout(() => {
            btn.classList.remove('copy-button--copied');
            label.textContent = original;
        }, 1500);
    }

    // Copy text to the clipboard. navigator.clipboard only exists in a secure
    // context (HTTPS/localhost), so fall back to a hidden textarea + execCommand
    // when it's unavailable (e.g. the page is served over plain HTTP).
    async function copyText(text) {
        if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(text);
            return;
        }

        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();
        try {
            if (!document.execCommand('copy')) throw new Error('execCommand copy failed');
        } finally {
            document.body.removeChild(textarea);
        }
    }

    async function copyMixUrl(btn) {
        const form = document.querySelector('.mix-form');
        const url = form.action + '?' + new URLSearchParams(new FormData(form));

        try {
            await copyText(url);
            flashButton(btn, 'Copied!');
        } catch (err) {
            console.error('Failed to copy URL:', err);
        }
    }

    // Render the mixer section (title + form + recipe) to a PNG blob, skipping
    // the copy buttons. Returns a Promise<Blob> synchronously so the caller
    // keeps the user gesture alive while the image renders.
    function getMixImage() {
        const target = document.querySelector('.mixer');
        return htmlToImage.toBlob(target, {
            pixelRatio: 2,
            backgroundColor: getComputedStyle(document.body).backgroundColor,
            filter: (node) => !(node.classList && node.classList.contains('btn-wrapper'))
        });
    }

    // Write a PNG blob to the clipboard, trying the forms different browsers accept.
    async function writeImageToClipboard() {
        if (!navigator.clipboard || !window.ClipboardItem || !window.isSecureContext) {
            throw new Error('Clipboard image API unavailable (needs HTTPS + a supporting browser)');
        }

        try {
            // Chrome/Safari: passing the promise keeps the user gesture alive
            // while the image renders.
            await navigator.clipboard.write([
                new ClipboardItem({ 'image/png': getMixImage() })
            ]);
        } catch (promiseErr) {
            // Firefox (and others) reject a promise value — resolve the blob first.
            const blob = await getMixImage();
            await navigator.clipboard.write([
                new ClipboardItem({ 'image/png': blob })
            ]);
        }
    }

    async function copyMixImage(btn) {
        try {
            await writeImageToClipboard();
            flashButton(btn, 'Copied!');
        } catch (err) {
            // Expected when the browser can't write images (e.g. no HTTPS) — download instead.
            try {
                const blob = await getMixImage();
                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.download = 'mix.png';
                link.href = url;
                link.click();
                URL.revokeObjectURL(url);
                flashButton(btn, 'Saved!');
            } catch (fallbackErr) {
                console.error('Failed to export image:', fallbackErr);
            }
        }
    }

    // Without a secure context (HTTPS) the browser can't copy images to the clipboard,
    // so label the button honestly as a download.
    if (!(navigator.clipboard && window.ClipboardItem && window.isSecureContext)) {
        const imageLabel = document.querySelector('button[onclick*="copyMixImage"] .copy-button__label');
        if (imageLabel) imageLabel.textContent = 'Save Image';
    }
</script>
