<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Schedule 1 Calculator</title>

    @{
        var ogBase = $"{Context.Request.Scheme}://{Context.Request.Host}";
    }
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Schedule 1 Calculator" />
    <meta property="og:title" content="@ViewData["Title"] · Schedule 1 Calculator" />
    <meta property="og:description" content="Find the most profitable recipe for any product in Schedule 1." />
    <meta property="og:image" content="@(ogBase)/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@ViewData["Title"] · Schedule 1 Calculator" />
    <meta name="twitter:description" content="Find the most profitable recipe for any product in Schedule 1." />
    <meta name="twitter:image" content="@(ogBase)/og-image.png" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="site-nav">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="brand__mark">S1</span>
                <span class="brand__text">Schedule&nbsp;1 <em>Calculator</em></span>
            </a>
            <ul class="site-nav__links">
                <li><a asp-controller="Home" asp-action="Index">Calculator</a></li>
                <li><a asp-controller="Home" asp-action="About">About</a></li>
            </ul>
        </nav>
    </header>

    <main role="main" class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <span>&copy; @DateTime.Now.Year Schedule 1 Calculator</span>
        <span class="site-footer__note">Fan-made companion tool for the game Schedule 1.</span>
        <a asp-controller="Home" asp-action="Privacy">Privacy</a>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
